{
  "name": "tribook-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "tick": "tsx src/cli/tick.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "engines": { "node": ">=20" },
  "dependencies": {
    "@google/genai": "^2.9.0",
    "@mysten/deepbook-v3": "^1.5.1",
    "@mysten/sui": "^2.19.0",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.2",
    "postgres": "^3.4.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1"
  }
}
